{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "totalPayment": {
      "type": "decimal",
      "required": true
    },
    "idPayment": {
      "type": "string",
      "required": false
    },
    "addressShiping": {
      "type": "json",
      "required": true
    },
    "products": {
      "type": "json",
      "required": true
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "Pedido creado",
        "Pago confirmado",
        "Preparando tu café",
        "Enviado",
        "Entregado",
        "Cancelado"
      ]
    }
  }
}
